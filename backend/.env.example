# === CareerCompass AI Backend Environment ===
# Copy this file to .env and fill in your values

# Gemini API Key (get from https://ai.google.dev)
GOOGLE_GENAI_API_KEY=your_gemini_api_key_here

# MongoDB Atlas Connection String
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/careercompass?retryWrites=true&w=majority

# CORS Allowed Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:4000

# Rate Limiting
RATE_LIMIT_PER_DAY=20

# Server
HOST=0.0.0.0
PORT=8000
